// Spreetail — Prisma Schema
// All financial data is stored in base currency units (paise would be ideal but we use decimals for clarity)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?  @map("password_hash") // null for Google OAuth users
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  groupMemberships  GroupMember[]
  expensesPaid      Expense[]        @relation("ExpensePaidBy")
  expenseSplits     ExpenseSplit[]
  settlementsFrom   Settlement[]     @relation("SettlementFrom")
  settlementsTo     Settlement[]     @relation("SettlementTo")
  groupsCreated     Group[]          @relation("GroupCreatedBy")
  importJobsCreated ImportJob[]
  issueResolutions  ImportIssue[]    @relation("IssueResolvedBy")

  @@map("users")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  baseCurrency String  @default("INR") @map("base_currency")
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String   @map("created_by_id")

  // Relations
  createdBy   User          @relation("GroupCreatedBy", fields: [createdById], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  importJobs  ImportJob[]

  @@map("groups")
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String    @map("group_id")
  userId   String    @map("user_id")
  joinedAt DateTime  @map("joined_at")
  leftAt   DateTime? @map("left_at")
  role     String    @default("member") // "admin" | "member"

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

enum SplitType {
  EQUAL
  UNEQUAL
  PERCENTAGE
  SHARE
}

model Expense {
  id          String    @id @default(cuid())
  groupId     String    @map("group_id")
  description String
  amount      Decimal   @db.Decimal(12, 4)
  currency    String    @default("INR")
  paidById    String?   @map("paid_by_id") // nullable: unknown payer
  date        DateTime
  splitType   SplitType @map("split_type")
  notes       String?
  isRefund    Boolean   @default(false) @map("is_refund")
  isSettlement Boolean  @default(false) @map("is_settlement")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  importJobId String?   @map("import_job_id")

  // Relations
  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy    User?          @relation("ExpensePaidBy", fields: [paidById], references: [id])
  splits    ExpenseSplit[]
  importJob ImportJob?     @relation(fields: [importJobId], references: [id])

  @@map("expenses")
}

model ExpenseSplit {
  id         String   @id @default(cuid())
  expenseId  String   @map("expense_id")
  userId     String   @map("user_id")
  amount     Decimal  @db.Decimal(12, 4) // INR amount this person owes
  percentage Decimal? @db.Decimal(8, 4)  // for percentage splits
  shares     Int?                         // for share-based splits
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

model Settlement {
  id           String   @id @default(cuid())
  groupId      String   @map("group_id")
  fromUserId   String   @map("from_user_id")
  toUserId     String   @map("to_user_id")
  amount       Decimal  @db.Decimal(12, 4)
  currency     String   @default("INR")
  date         DateTime
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser User  @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("SettlementTo", fields: [toUserId], references: [id])

  @@map("settlements")
}

model ExchangeRate {
  id             String   @id @default(cuid())
  fromCurrency   String   @map("from_currency")
  toCurrency     String   @map("to_currency")
  rate           Decimal  @db.Decimal(12, 6)
  effectiveDate  DateTime @map("effective_date")
  source         String   @default("manual") // "manual" | "api"
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([fromCurrency, toCurrency, effectiveDate])
  @@map("exchange_rates")
}

enum ImportStatus {
  PENDING
  PROCESSING
  NEEDS_REVIEW
  COMPLETED
  FAILED
}

model ImportJob {
  id           String       @id @default(cuid())
  groupId      String       @map("group_id")
  filename     String
  status       ImportStatus @default(PENDING)
  totalRows    Int          @default(0) @map("total_rows")
  importedRows Int          @default(0) @map("imported_rows")
  flaggedRows  Int          @default(0) @map("flagged_rows")
  skippedRows  Int          @default(0) @map("skipped_rows")
  createdAt    DateTime     @default(now()) @map("created_at")
  completedAt  DateTime?    @map("completed_at")
  createdById  String       @map("created_by_id")

  // Relations
  group     Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User          @relation(fields: [createdById], references: [id])
  issues    ImportIssue[]
  expenses  Expense[]

  @@map("import_jobs")
}

enum IssueSeverity {
  HIGH
  MEDIUM
  LOW
}

enum IssueType {
  DUPLICATE_EXPENSE
  SETTLEMENT_AS_EXPENSE
  UNKNOWN_PAYER
  MISSING_PAYER
  PERCENTAGE_SUM_ERROR
  NEGATIVE_AMOUNT
  MALFORMED_DATE
  MISSING_CURRENCY
  ZERO_AMOUNT
  AMBIGUOUS_DATE
  MEMBERSHIP_CONFLICT
  SPLIT_TYPE_CONTRADICTION
  NON_INTEGER_AMOUNT
  UNKNOWN_MEMBER_IN_SPLIT
}

enum IssueResolution {
  PENDING
  KEEP
  SKIP
  MODIFIED
  AUTO_RESOLVED
}

model ImportIssue {
  id              String          @id @default(cuid())
  importJobId     String          @map("import_job_id")
  rowNumber       Int             @map("row_number")
  rawData         Json            @map("raw_data")
  issueType       IssueType       @map("issue_type")
  severity        IssueSeverity
  description     String
  suggestedAction String          @map("suggested_action")
  resolution      IssueResolution @default(PENDING)
  resolvedData    Json?           @map("resolved_data") // user-modified row data
  resolvedById    String?         @map("resolved_by_id")
  resolvedAt      DateTime?       @map("resolved_at")

  // Relations
  importJob  ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  resolvedBy User?     @relation("IssueResolvedBy", fields: [resolvedById], references: [id])

  @@map("import_issues")
}
